{
  "name": "paleoMem",
  "version": "0.1.0",
  "private": true,
  "author": "Brian McConnel",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-pwa-icons.js",
    "icons:regenerate": "node scripts/generate-pwa-icons.js --regenerate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "verify:display": "node scripts/verify-display.js --write-report",
    "data:fetch": "node scripts/fetch-bible-data.js && node scripts/fetch-hebrew-ot.js && node scripts/convert-strongs.js"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
